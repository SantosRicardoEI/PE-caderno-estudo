---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import TOC from '../components/TOC.astro';

const entry = await getEntry('caderno', 'inicio');
if (!entry) throw new Error('Falta o conteúdo de início (inicio.md).');
const { Content, headings } = await render(entry);
---
<BaseLayout title={entry.data.titulo} description={entry.data.resumo} current="inicio">
  <main class="prose" id="conteudo">
    <Content />
  </main>
  <TOC slot="aside" headings={headings} />
</BaseLayout>
